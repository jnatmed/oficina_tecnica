{% extends "layout.twig" %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="card shadow border-0 animate__animated animate__fadeIn">
            <div class="card-header bg-warning text-dark py-3 d-flex align-items-center justify-content-between">
                <div>
                    <i class="bi bi-pencil-square me-2"></i>
                    <h5 class="mb-0 d-inline-block">Editar Manual Técnico</h5>
                </div>
                <span class="badge bg-dark text-warning">Modo Edición</span>
            </div>
            <div class="card-body p-4">
                <form id="formEditarManual" action="/editar/{{ problema.id }}" method="POST" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary">Título del Problema</label>
                        <input type="text" name="titulo" class="form-control border-2" value="{{ problema.titulo }}" required>
                    </div>

                    <div id="lista-pasos">
                        <label class="form-label fw-bold text-secondary mb-3">Pasos de la Solución</label>
                        
                        {% for paso in problema.pasos %}
                            <div class="paso-container p-3 border rounded-3 bg-light mb-3 position-relative" onpaste="manejarPegado(event, this)">
                                {# Campo oculto para mantener referencia al ID del paso para el backend #}
                                <input type="hidden" name="pasos_id[]" value="{{ paso.id }}">
                                
                                <div class="d-flex align-items-center mb-2">
                                    <span class="badge bg-primary rounded-pill me-2">{{ paso.orden }}</span>
                                    <input type="text" name="pasos_desc[]" class="form-control form-control-sm" value="{{ paso.descripcion }}" required>
                                </div>
                                
                                <div class="row align-items-center g-2">
                                    <div class="col">
                                        <input type="file" name="imagenes_pasos" class="form-control form-control-sm input-archivo">
                                    </div>
                                    {% if paso.imagen_url %}
                                    <div class="col-auto">
                                        <div class="position-relative group-image-preview">
                                            <img src="{{ paso.imagen_url }}" 
                                                 class="rounded border shadow-sm img-hover-zoom" 
                                                 style="height: 45px; width: 70px; object-fit: cover; cursor: pointer;" 
                                                 onclick="verImagenFull('{{ paso.imagen_url }}', 'Imagen Actual - Paso {{ paso.orden }}')"
                                                 title="Click para ampliar">
                                            <div class="text-center mt-1" style="font-size: 0.6rem; color: #666;">Actual</div>
                                        </div>
                                    </div>
                                    {% endif %}
                                </div>
                                <div class="preview-container mt-2"></div>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="agregarCampoPaso()">
                            <i class="bi bi-plus-lg me-1"></i> Agregar un paso adicional
                        </button>
                        <hr class="my-3">
                        <div class="row g-2">
                            <div class="col-8">
                                <button type="submit" class="btn btn-success w-100 shadow-sm py-2">
                                    <i class="bi bi-check2-circle me-2"></i>Guardar Cambios
                                </button>
                            </div>
                            <div class="col-4">
                                <a href="/" class="btn btn-outline-secondary w-100 py-2">Cancelar</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{# Modal de imagen integrado y corregido para evitar conflictos de inicialización #}
<div class="modal fade" id="modalImagenEdit" tabindex="-1" aria-hidden="true" style="z-index: 3000;">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 bg-dark shadow-lg">
            <div class="modal-header border-0 p-3">
                <h5 class="modal-title text-white" id="modalTituloEdit"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <img src="" id="imgFullEdit" class="img-fluid rounded shadow-lg animate__animated animate__zoomIn">
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Inicialización segura del modal usando el evento DOMContentLoaded
    let editModal;
    document.addEventListener('DOMContentLoaded', () => {
        const modalEl = document.getElementById('modalImagenEdit');
        if (modalEl) {
            editModal = new bootstrap.Modal(modalEl);
        }
    });

    /**
     * Muestra la imagen en pantalla completa
     */
    function verImagenFull(url, titulo) {
        if (!editModal) return;
        document.getElementById('imgFullEdit').src = url;
        document.getElementById('modalTituloEdit').innerText = titulo;
        editModal.show();
    }

    /**
     * Maneja el pegado de imágenes desde el portapapeles
     */
    function manejarPegado(event, contenedor) {
        const items = (event.clipboardData || event.originalEvent.clipboardData).items;
        const inputArchivo = contenedor.querySelector('.input-archivo');
        const previewContainer = contenedor.querySelector('.preview-container');

        for (const item of items) {
            if (item.type.indexOf("image") !== -1) {
                const blob = item.getAsFile();
                const archivo = new File([blob], `edit_captura_${Date.now()}.png`, { type: blob.type });

                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(archivo);
                inputArchivo.files = dataTransfer.files;

                const reader = new FileReader();
                reader.onload = (e) => {
                    previewContainer.innerHTML = `
                        <div class="position-relative d-inline-block mt-2 animate__animated animate__fadeIn">
                            <img src="${e.target.result}" class="img-thumbnail border-primary shadow-sm" style="height: 100px;">
                            <span class="badge bg-success position-absolute top-0 start-100 translate-middle rounded-circle shadow">
                                <i class="bi bi-check"></i>
                            </span>
                            <small class="text-primary d-block fw-bold mt-1">Nueva imagen lista</small>
                        </div>`;
                };
                reader.readAsDataURL(blob);
                
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Captura detectada correctamente',
                    showConfirmButton: false,
                    timer: 2000
                });
            }
        }
    }

    /**
     * Añade dinámicamente nuevos campos de pasos
     */
    function agregarCampoPaso() {
        const container = document.getElementById('lista-pasos');
        const index = container.getElementsByClassName('paso-container').length + 1;
        const div = document.createElement('div');
        div.className = 'paso-container p-3 border rounded-3 bg-white mb-3 shadow-sm animate__animated animate__fadeInLeft position-relative';
        div.setAttribute('onpaste', 'manejarPegado(event, this)');
        
        // Reemplaza solo este bloque dentro de la función agregarCampoPaso()
        div.innerHTML = `
            <button type="button" class="btn-close position-absolute top-0 end-0 m-2" style="font-size: 0.7rem; z-index: 2;" title="Quitar este nuevo paso" onclick="this.parentElement.remove()"></button>
            
            <div class="pe-4">
                <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-info text-dark rounded-pill me-2">${index}</span>
                    <input type="text" name="pasos_desc[]" class="form-control form-control-sm border-info" placeholder="Descripción del nuevo paso..." required>
                </div>
                <input type="file" name="imagenes_pasos" class="form-control form-control-sm input-archivo">
                <div class="preview-container mt-2"></div>
            </div>
        `;
        container.appendChild(div);
    }

    // Confirmación con SweetAlert2 antes de procesar el formulario
    document.getElementById('formEditarManual').onsubmit = function(e) {
        e.preventDefault();
        Swal.fire({
            title: '¿Guardar los cambios?',
            text: "Se actualizará el contenido del manual en la base de datos.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#198754',
            cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="bi bi-save me-1"></i> Sí, actualizar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                this.submit();
            }
        });
    };
</script>

<style>
    .paso-container { transition: all 0.2s; border-width: 2px !important; }
    .paso-container:hover { border-color: #ffc107 !important; }
    .img-hover-zoom { transition: transform 0.2s; }
    .img-hover-zoom:hover { transform: scale(1.1); }
</style>
{% endblock %}