<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Oficina Técnica - Base de Conocimientos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f0f2f5; }
        .navbar-brand { font-weight: 600; }
        /* Mejora del hover en las tarjetas de conocimiento */
        .card-manual { transition: all 0.3s ease; border: none; border-radius: 12px; }
        .card-manual:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🛠 Oficina Técnica</a>
            {% if user %}
                <div class="d-flex align-items-center">
                    <span class="text-secondary small me-3 d-none d-md-block">{{ user.email }}</span>
                    <a class="btn btn-outline-danger btn-sm fw-bold" href="/auth/logout">Cerrar Sesión</a>
                </div>
            {% endif %}
        </div>
    </nav>

    <main class="container pb-5">
        {% block body %}{% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>