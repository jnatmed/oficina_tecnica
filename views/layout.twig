<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Oficina Técnica - Base de Conocimientos</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f0f2f5; }
        .navbar-brand { font-weight: 600; }
        .card-manual { transition: all 0.3s ease; border: none; border-radius: 12px; }
        .card-manual:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important; }
        
        /* Estilo para las imágenes clickeables */
        .img-pointer { cursor: zoom-in; transition: filter 0.2s; }
        .img-pointer:hover { filter: brightness(0.8); }
            .transition-icon {
                    transition: transform 0.3s ease;
                }
            {# Rota el icono 90 grados cuando el colapso no está contraído #}
            .card-header:not(.collapsed) .transition-icon {
                transform: rotate(90deg);
            }                
            .card-header[aria-expanded="true"] .transition-icon {
                transform: rotate(90deg);
            }
            .card-manual {
                transition: transform 0.2s;
            }
            .card-manual:hover {
                transform: translateY(-2px);
            }        
    </style>
</head>
<body>
    {# 1. Lógica para ocultar menú en vista pública #}
    {% if not esPublico %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🛠 Oficina Técnica</a>
            {% if user %}
                <div class="d-flex align-items-center">
                    <span class="text-secondary small me-3 d-none d-md-block">{{ user.email }}</span>
                    <a class="btn btn-outline-danger btn-sm fw-bold" href="/auth/logout">Cerrar Sesión</a>
                </div>
            {% endif %}
        </div>
    </nav>
    {% else %}
    {# Encabezado minimalista para externos #}
    <div class="py-4 text-center animate__animated animate__fadeIn">
        <h2 class="text-primary fw-bold mb-0">🛠 Oficina Técnica</h2>
        <p class="text-muted small">Base de Conocimientos Pública</p>
    </div>
    {% endif %}

    <main class="container pb-5">
        {% block body %}{% endblock %}
    </main>

    {# 2. Modal Global para visualización de capturas #}
    <div class="modal fade" id="modalGlobal" tabindex="-1" aria-hidden="true" style="z-index: 3000;">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content bg-dark border-0 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title text-white" id="modalGlobalTitulo"></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <img src="" id="imgGlobalFull" class="img-fluid rounded shadow-lg animate__animated animate__zoomIn">
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        /**
         * 3. Función global para abrir el modal de imagen.
         * Se asegura de inicializar la instancia de Bootstrap correctamente.
         */
        function verImagen(url, titulo) {
            const modalEl = document.getElementById('modalGlobal');
            const imgEl = document.getElementById('imgGlobalFull');
            const tituloEl = document.getElementById('modalGlobalTitulo');

            if (modalEl && imgEl) {
                imgEl.src = url;
                tituloEl.innerText = titulo || 'Visualización de Captura';
                
                // Obtiene o crea la instancia del modal de Bootstrap
                const modalInstance = bootstrap.Modal.getOrCreateInstance(modalEl);
                modalInstance.show();
            }
        }
    </script>
</body>
</html>